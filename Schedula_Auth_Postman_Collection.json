{
  "info": {
    "_postman_id": "schedula-auth-collection",
    "name": "Schedula Authentication API",
    "description": "Complete authentication and role-based authorization API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Signup",
      "item": [
        {
          "name": "Signup Doctor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Rahul\",\n  \"email\": \"doctor@gmail.com\",\n  \"password\": \"password123\",\n  \"role\": \"DOCTOR\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "signup"]
            }
          }
        },
        {
          "name": "Signup Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya\",\n  \"email\": \"patient@gmail.com\",\n  \"password\": \"password123\",\n  \"role\": \"PATIENT\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "signup"]
            }
          }
        }
      ]
    },
